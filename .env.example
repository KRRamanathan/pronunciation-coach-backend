# Runs with zero configured secrets — all variables below are optional.
# Copy to .env and uncomment only what you need.

# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# Default: local SQLite (fine for dev; use Supabase Postgres in production)

# CORS_ORIGINS=https://your-frontend.vercel.app
# Default: * (restrict in production)

# RETENTION_DAYS=30

# Optional cosmetic polish only — app works fully without this.
# Get a free key (no credit card) from https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# GEMINI_MODEL=gemini-2.0-flash

# HF_SPACE_REGION=us-east-1
# SUPABASE_REGION=ap-south-1
